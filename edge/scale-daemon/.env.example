# scale-daemon configuration reference
#
# All options are read from environment variables (see scale-daemon.service / /etc/omnigate/scale.env).
# Every variable has a matching CLI flag with the same semantics (--scale-host, --api-key, …).
# CLI flags override environment variables.

# ── Scale hardware ────────────────────────────────────────────────────────────

# TCP host where the scale controller is listening.
# For a serial-to-Ethernet converter or a direct Ethernet scale set the LAN IP.
SCALE_HOST: "192.168.1.100"

# TCP port of the scale.
SCALE_PORT: "5001"

# Seconds to wait before reconnecting after a lost connection.
# RECONNECT_SEC: 5

# ── OmniGate gateway ─────────────────────────────────────────────────────────

# Full URL of the ingestor endpoint, reachable from this edge device.
# Traffic goes through the NGINX gateway which validates the API key and
# injects X-Source-ID / X-Gate-ID headers before forwarding to the ingestor.
INGESTOR_URL: "http://omnigate.example.com:8090/ingest/event"

# API key for the device registered in OmniGate (Settings → Devices → API Key).
# Sent as "Authorization: Bearer <API_KEY>".
API_KEY: "your-device-api-key-here"

# Human-readable device identifier used only in local log output.
DEVICE_ID: "scale-gate-01"

# ── Debounce / filtering ──────────────────────────────────────────────────────

# How long (milliseconds) the parsed weight must stay constant before the
# daemon sends it to the ingestor.  Increase for noisy scales.
# DEBOUNCE_MS: 2000

# Readings below this threshold are silently ignored.  Useful to suppress
# near-zero noise when the scale is empty.  Set to 0 to report everything.
# MIN_WEIGHT_KG: 0

# ── Observability ─────────────────────────────────────────────────────────────

# OTLP HTTP collector endpoint (host:port, no scheme).
# Both structured logs and traces are exported here via HTTP/protobuf.
# If the collector is unreachable the daemon continues with stdout-only logging.
# OTEL_ENDPOINT: "localhost:4318"
