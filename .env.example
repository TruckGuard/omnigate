# =============================================
# Database
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

AUTH_DB_NAME=omnigate_auth
AUTH_USER=auth_user
AUTH_PASSWORD=auth_password

CORE_DB_NAME=omnigate_core
CORE_USER=core_user
CORE_PASSWORD=core_password

# =============================================
# Storage – Dev (MinIO)
# =============================================
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_BUCKET=omnigate-data

# =============================================
# Storage – Prod (Garage)
# =============================================
GARAGE_RPC_SECRET=change_me_64_hex_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GARAGE_ADMIN_TOKEN=change_me_admin_token
STORAGE_ENDPOINT=garage:3900
STORAGE_ACCESS_KEY=change_me_access_key
STORAGE_SECRET_KEY=change_me_secret_key
STORAGE_BUCKET=omnigate-data

# =============================================
# Cache / Event Bus
# =============================================
VALKEY_ADDR=valkey:6379

# =============================================
# Auth & Security
# =============================================
WORKER_SYSTEM_KEY=change_me_worker_system_key
PULLER_API_KEY=change_me_puller_api_key
ADMIN_DEFAULT_PASSWORD=change_me_admin_password

# =============================================
# Service URLs (defaults match Docker Compose)
# =============================================
CORE_URL=http://gateway/api/v1
PULLER_URL=http://puller:8000
INGESTOR_URL=http://gateway/ingest

# =============================================
# Ports
# =============================================
PORT=8080
