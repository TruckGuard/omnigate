      "query": {
        "builder": {
          "queryData": [
            {
              "aggregateAttribute": {
                "dataType": "string",
                "id": "------false",
                "isColumn": false,
                "key": "",
                "type": ""
              },
              "aggregateOperator": "count",
              "dataSource": "metrics",
              "disabled": false,
              "expression": "A",
              "filter": {"expression": ""},
              "functions": [],
              "groupBy": [],
