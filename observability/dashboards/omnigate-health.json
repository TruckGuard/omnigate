          {
            "disabled": false,
            "legend": "{{instance}}",
            "name": "A",
            "query": "probe_success{job=\"omnigate-health\"}"
          }
        ],
        "queryType": "promql"
      },
      "softMax": 1,
      "softMin": 0,
